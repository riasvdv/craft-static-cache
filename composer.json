{
    "name": "rias/craft-static-cache",
    "description": "Full-page static caching for Craft CMS.",
    "type": "craft-plugin",
    "license": "MIT",
    "require": {
        "ext-uri": "*",
        "php": "^8.5",
        "craftcms/cms": "*"
    },
    "require-dev": {
        "carthage-software/mago": "^1.26",
        "nunomaduro/collision": "^8.1.1",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Rias\\CraftStaticCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rias\\CraftStaticCache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/mago analyze src",
        "lint": "vendor/bin/mago lint --minimum-report-level=error",
        "format": "vendor/bin/mago fmt",
        "format-check": "vendor/bin/mago fmt --check",
        "test": "vendor/bin/pest --parallel",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "handle": "static-cache",
        "name": "Craft Static Cache",
        "developer": "Rias",
        "developerUrl": "https://rias.be",
        "documentationUrl": "https://github.com/riasvdv/craft-static-cache",
        "class": "Rias\\CraftStaticCache\\StaticCache",
        "laravel": {
            "providers": [
                "Rias\\CraftStaticCache\\StaticCache"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
